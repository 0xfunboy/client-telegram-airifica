###############################################
#### client-telegram-airifica Configuration ###
###############################################

# The Telegram client reads AIRIFICA_ first and then falls back to AIRI3_ for
# compatibility with the current Airifica runtime contract.

AIRI3_PORT=4040
AIRI3_PUBLIC_APP_URL=https://airi.airewardrop.xyz

# Required to actually start the Telegram bot
AIRI3_TELEGRAM_BOT_TOKEN=
AIRI3_TELEGRAM_BOT_USERNAME=AIRificabot

# Internal secret shared with client-airifica runtime
AIRI3_TELEGRAM_INTERNAL_SECRET=
AIRI3_TELEGRAM_RUNTIME_BASE_URL=http://127.0.0.1:4040

# Polling and alert cadence
AIRI3_TELEGRAM_POLL_TIMEOUT_SECONDS=50
AIRI3_TELEGRAM_ALERT_POLL_MS=5000
